<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:soundCloudArchiver.ViewModels"
    x:Class="soundCloudArchiver.Views.ConfirmationDialog"
    x:DataType="vm:ConfirmationDialogViewModel"
    Title="{Binding Title}"
    Width="500" Height="450"
    WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <TextBlock Grid.Row="0" Text="{Binding Title}"
            FontSize="20" FontWeight="Bold"
            HorizontalAlignment="Center" Margin="0 0 0 15" />

        <ScrollViewer Grid.Row="1"
            MaxHeight="300" VerticalScrollBarVisibility="Auto"
            VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="{Binding Message}"
                    TextWrapping="Wrap" FontSize="18" />
                <CheckBox IsChecked="{Binding IsChecked}"
                    IsVisible="{Binding ShowCheckbox}"
                    Content="{Binding CheckboxLabel}"
                    Margin="0 15 0 0" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
            HorizontalAlignment="Center"
            Spacing="20" Margin="0 15 0 0">
            <Button Content="OK"
                Click="OnOkClicked"
                Width="100" />
            <Button Content="Cancel"
                Click="OnCancelClicked"
                Width="100" />
        </StackPanel>
    </Grid>
</Window>
